# --- Supabase (shared by web + worker) ---
# Public (browser-safe) — used by the Next.js app
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# Server-only — BFF route handlers + Python worker
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# Direct Postgres connection — used by the worker's job poller
# (FOR UPDATE SKIP LOCKED queue consumption)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- LLM provider (LangGraph nodes) ---
# Stack permits OpenAI or Anthropic; set the one you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Rate-limit resilience (optional). The client retries each call with backoff;
# a transient failure that still surfaces requeues the job until MAX_ATTEMPTS.
# OPENAI_MAX_RETRIES=8
# MAX_ATTEMPTS=5

# --- Web / product research tool (research node) ---
# Tavily API key. Leave empty to disable web research (the node no-ops and
# fields stay source="llm"); set it to ground vendor + barcode as source="web".
WEB_SEARCH_API_KEY=

# --- Observability: LangSmith tracing (optional, worker) ---
# Off unless LANGSMITH_TRACING=true *and* an API key are set. When enabled, each
# LangGraph enrichment run is traced (node spans + OpenAI prompts/tokens) to
# LangSmith — complementing the `runs` table, not replacing it.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=supplier-enrichment
# LANGSMITH_ENDPOINT=          # only for self-hosted / EU LangSmith
